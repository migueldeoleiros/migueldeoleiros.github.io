---
import About from '../components/About.astro';
import AboutContent from '../content/about.md';
import GardenCard from '../components/GardenCard.astro';
import Hero from '../components/Hero.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { aboutCopy, heroCopy, pageMeta, socialLinks, themeLabels } from '../data/site';
import '../styles/global.css';
---

<BaseLayout title={pageMeta.title} description={pageMeta.description}>
	<ThemeToggle label={themeLabels.toggleControl} />

	<main>
		<Hero copy={heroCopy} links={socialLinks} />

		<div class="page-content">
			<GardenCard />

			<About copy={aboutCopy}>
				<AboutContent />
			</About>
		</div>
	</main>

	<script>
		import { initSiteInteractions } from '../scripts';

		initSiteInteractions();
	</script>
</BaseLayout>
